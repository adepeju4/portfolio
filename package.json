  "version": "0.0.1",
  "type": "module",
  "packageManager": "pnpm@8.6.0",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
